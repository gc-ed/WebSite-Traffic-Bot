TARGET_URL=https://example.com
SESSIONS_PER_RUN=10
PAGES_PER_SESSION=4
DWELL_TIME_MIN=15
DWELL_TIME_MAX=60
SCROLL_SIMULATION=true
USER_AGENT_ROTATE=true
# Comma-separated list of proxy URLs
# Example: PROXY_LIST=http://192.168.1.100:8080,http://192.168.1.101:8080
PROXY_LIST=
KPI_LOG_PATH=/logs/kpi.log
RUN_INTERVAL_MIN=30
AUTO_DISCOVER_ROUTES=true
